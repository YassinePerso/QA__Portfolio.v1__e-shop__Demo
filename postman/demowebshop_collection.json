						{
							"listen": "test",
							"script": {
								"exec": [
									"// Expected status code 201 (Created)",
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"// Fetching data from POST request to check",
									"pm.test(\"Response contains created post data\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id'); //Expecting id property",
									"    pm.expect(jsonData.title).to.equal(\"POST request / API Testing\");   //Expecting title property",
									"    pm.expect(jsonData.userId).to.equal(pm.collectionVariables.get(\"user_id\")); //Collecting and storing id ID user_id variable ",
									"});",
									"",
									"// Store post ID for chaining",
									"pm.test(\"Post ID stored for chaining\", function () {",
									"    const jsonData = pm.response.json(); //.json() so store data in JSON format",
									"    pm.collectionVariables.set(\"post_id\", 8); // chaining",
									"    pm.expect(pm.collectionVariables.get(\"post_id\")).to.not.be.undefined; // must not be empty",
									"});",
									"",
									"// Expected response time must be less than 2 seconds ",
									"pm.test(\"Response time is less than 2000ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});"
