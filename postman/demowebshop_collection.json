		{
			"name": "GET Request",
			"item": [
				{
					"name": "Get /users",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Expected status code is 200 (OK)",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Expecting response is an array with data (length greater than 0)",
									"pm.test(\"Response is a non-empty array\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"    pm.expect(jsonData.length).to.be.greaterThan(0);",
									"});",
									"",
									"// Expected response time must be less than 2 seconds ",
									"pm.test(\"Response time is less than 2000ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});",
									"",
									"// Expected properties like id, name, email and username",
									"pm.test(\"User object has required fields\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData[0]).to.have.property('id');",
									"    pm.expect(jsonData[0]).to.have.property('name');",
									"    pm.expect(jsonData[0]).to.have.property('email');",
									"    pm.expect(jsonData[0]).to.have.property('username');",
									"});",
									"",
									"// Store first user ID for chaining",
									"pm.collectionVariables.set(\"user_id\", pm.response.json()[0].id);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}users/",
							"host": [
								"{{base_url}}users"
							],
							"path": [
								""
							]
						}
					},
					"response": []
				}
			]
		},
		{
